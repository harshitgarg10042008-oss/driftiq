

# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT  (use strong random strings in production)
JWT_SECRET=change_me_super_secret_jwt_key
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_STORAGE_CHAT_ID=-100xxxxxxxxxx   # ID of the private channel used as storage
TELEGRAM_WEBHOOK_URL=https://your-backend.onrender.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=any_random_secret_string

# Frontend URL (used for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Email (optional — only needed for password reset emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
