{
  "name": "driftiq-root",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "echo \"Monorepo: Please open two terminals. Run 'npm run start:backend' in one, and 'npm run start:frontend' in the other.\"",
    "start:backend": "npm run start:dev --workspace=apps/backend",
    "start:frontend": "npm run dev --workspace=apps/frontend",
    "build": "npm run build --workspaces",
    "install:all": "npm install --legacy-peer-deps"
  }
}
